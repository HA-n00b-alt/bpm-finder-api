# GCP Cloud Run deployment configuration
PROJECT_ID=delman-site
REGION=europe-west3

# Optional: Cloudflare R2 centralized manifest (web repos only — not required for GCP microservices)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_MANIFEST_KEY=bpm-finder-api/production.json

# Optional: set DEPLOY_FORCE=1 to redeploy all services regardless of content hash
# Optional: set DEPLOY_SKIP_GIT_COMMIT=1 to skip the interactive git commit/push prompts
